{
  "name": "mobile-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eas-build-pre-install": "chmod -R u+rwX . || true",
    "build:android:internal": "eas build --platform android --profile internal",
    "build:ios:internal": "eas build --platform ios --profile internal",
    "build:android:prod": "eas build --platform android --profile production",
    "build:ios:prod": "eas build --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "expo": "~55.0.7",
    "expo-auth-session": "^55.0.9",
    "expo-constants": "^55.0.9",
    "expo-status-bar": "~55.0.4",
    "expo-web-browser": "^55.0.10",
    "onesignal-expo-plugin": "^2.4.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-onesignal": "^5.4.0",
    "react-native-web": "^0.21.0",
    "react-native-webview": "^13.16.1"
  },
  "private": true,
  "devDependencies": {
    "eas-cli": "^18.4.0",
    "typescript": "^5.9.3"
  }
}
